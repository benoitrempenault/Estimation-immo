<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Estimation Immobilière — Assistant IA</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0e0f0e; --surface: #161714; --surface2: #1e1f1c;
    --border: #2a2b27; --gold: #c9a84c; --gold-light: #e8c97a;
    --text: #e8e6df; --muted: #7a7970;
    --green-bg: #1a2415; --green-border: #2d4020; --green-text: #c8e0b8;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; height:100vh; display:flex; flex-direction:column; overflow:hidden; }

  /* SETUP SCREEN */
  #setup {
    position:fixed; inset:0; background:var(--bg);
    display:flex; align-items:center; justify-content:center;
    z-index:999; padding:20px;
  }
  .setup-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:18px; padding:32px; max-width:400px; width:100%;
  }
  .setup-logo { font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:500; margin-bottom:4px; }
  .setup-sub { font-size:0.8rem; color:var(--muted); margin-bottom:24px; }
  .setup-label { font-size:0.72rem; color:var(--muted); text-transform:uppercase; letter-spacing:.07em; margin-bottom:6px; display:block; }
  .setup-input {
    width:100%; background:var(--surface2); border:1px solid var(--border);
    border-radius:10px; color:var(--text); font-family:'DM Sans',sans-serif;
    font-size:0.875rem; padding:11px 14px; outline:none;
    transition:border-color .2s; margin-bottom:14px;
  }
  .setup-input:focus { border-color:var(--gold); }
  .setup-input::placeholder { color:var(--muted); }
  .setup-btn {
    width:100%; padding:12px; border-radius:10px;
    background:linear-gradient(135deg, var(--gold), #8a6520);
    border:none; color:#1a1200; font-family:'DM Sans',sans-serif;
    font-size:0.9rem; font-weight:500; cursor:pointer; transition:opacity .2s;
  }
  .setup-btn:hover { opacity:.9; }
  .setup-err { font-size:0.75rem; color:#e07070; margin-top:8px; min-height:18px; }
  .setup-note { font-size:0.72rem; color:var(--muted); text-align:center; margin-top:14px; line-height:1.6; }
  .setup-note a { color:var(--gold); text-decoration:none; }

  /* APP */
  header {
    padding:14px 22px; border-bottom:1px solid var(--border);
    display:flex; align-items:center; gap:12px;
    background:var(--surface); flex-shrink:0;
  }
  .logo { width:34px; height:34px; border-radius:9px; background:linear-gradient(135deg,var(--gold),#7a5015); display:flex; align-items:center; justify-content:center; font-size:16px; }
  .h-title { font-family:'Cormorant Garamond',serif; font-size:1.2rem; font-weight:500; }
  .h-sub { font-size:0.7rem; color:var(--muted); letter-spacing:.07em; text-transform:uppercase; margin-top:1px; }
  .dot { width:7px; height:7px; border-radius:50%; margin-left:auto; background:#5a9e52; box-shadow:0 0 8px #5a9e5280; animation:pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

  #pbar { height:2px; background:var(--border); flex-shrink:0; }
  #pfill { height:100%; width:0%; background:linear-gradient(90deg,var(--gold),var(--gold-light)); transition:width .5s; }

  #chat { flex:1; overflow-y:auto; padding:20px 18px; display:flex; flex-direction:column; gap:13px; scroll-behavior:smooth; }
  #chat::-webkit-scrollbar { width:3px; }
  #chat::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }

  .msg { display:flex; gap:9px; animation:fi .28s ease forwards; opacity:0; }
  @keyframes fi { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .msg.bot { align-self:flex-start; max-width:88%; }
  .msg.usr { align-self:flex-end; flex-direction:row-reverse; max-width:75%; }

  .av { width:28px; height:28px; border-radius:8px; flex-shrink:0; margin-top:2px; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:500; }
  .bot .av { background:linear-gradient(135deg,var(--gold),#7a5015); color:#1a1200; }
  .usr .av { background:var(--surface2); border:1px solid var(--border); color:var(--muted); }

  .bbl { padding:9px 13px; border-radius:12px; font-size:.875rem; line-height:1.6; }
  .bot .bbl { background:var(--surface); border:1px solid var(--border); border-top-left-radius:3px; }
  .usr .bbl { background:var(--green-bg); border:1px solid var(--green-border); border-top-right-radius:3px; color:var(--green-text); }

  .slbl { font-size:.65rem; text-transform:uppercase; letter-spacing:.08em; color:var(--gold); margin-bottom:5px; font-weight:500; }

  .typ { display:flex; gap:4px; align-items:center; padding:3px 0; }
  .typ span { width:5px; height:5px; border-radius:50%; background:var(--muted); animation:bo 1.1s infinite; }
  .typ span:nth-child(2){animation-delay:.18s} .typ span:nth-child(3){animation-delay:.36s}
  @keyframes bo { 0%,80%,100%{transform:translateY(0);opacity:.35} 40%{transform:translateY(-5px);opacity:1} }

  .fiche { margin-top:8px; background:var(--surface2); border:1px solid var(--gold); border-radius:11px; padding:13px; }
  .fiche-t { font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--gold-light); margin-bottom:9px; }
  .fiche-st { font-size:.63rem; text-transform:uppercase; letter-spacing:.08em; color:var(--gold); margin-bottom:3px; margin-top:8px; font-weight:500; }
  .fiche p { font-size:.82rem; line-height:1.7; }

  #foot { padding:13px 18px; border-top:1px solid var(--border); background:var(--surface); flex-shrink:0; }
  #irow { display:flex; gap:9px; align-items:flex-end; }
  textarea { flex:1; background:var(--surface2); border:1px solid var(--border); border-radius:10px; color:var(--text); font-family:'DM Sans',sans-serif; font-size:.875rem; padding:10px 13px; resize:none; min-height:42px; max-height:110px; outline:none; line-height:1.5; transition:border-color .2s; }
  textarea:focus { border-color:var(--gold); }
  textarea::placeholder { color:var(--muted); }
  #sbtn { width:42px; height:42px; border-radius:10px; flex-shrink:0; background:linear-gradient(135deg,var(--gold),#8a6520); border:none; cursor:pointer; font-size:15px; color:#1a1200; display:flex; align-items:center; justify-content:center; transition:transform .15s,opacity .2s; }
  #sbtn:hover { transform:scale(1.05); }
  #sbtn:disabled { opacity:.4; cursor:not-allowed; transform:none; }
  .hint { font-size:.68rem; color:var(--muted); text-align:center; margin-top:6px; }
</style>
</head>
<body>

<!-- SETUP -->
<div id="setup">
  <div class="setup-card">
    <div class="setup-logo">🏛 Estimation Immobilière</div>
    <div class="setup-sub">Assistant IA — Agent immobilier</div>
    <label class="setup-label" for="kf">Clé API Anthropic</label>
    <input type="password" id="kf" class="setup-input" placeholder="sk-ant-api03-…" autocomplete="off" />
    <button class="setup-btn" onclick="launch()">Démarrer l'entretien ➤</button>
    <div class="setup-err" id="serr"></div>
    <div class="setup-note">
      Obtenez votre clé sur <a href="https://console.anthropic.com/settings/keys" target="_blank">console.anthropic.com</a><br>
      Elle reste stockée uniquement dans votre navigateur.
    </div>
  </div>
</div>

<!-- APP -->
<header>
  <div class="logo">🏛</div>
  <div><div class="h-title">Estimation Immobilière</div><div class="h-sub">Assistant IA — Agent immobilier</div></div>
  <div class="dot"></div>
</header>
<div id="pbar"><div id="pfill"></div></div>
<div id="chat"></div>
<div id="foot">
  <div id="irow">
    <textarea id="itx" placeholder="Votre réponse…" rows="1"></textarea>
    <button id="sbtn">➤</button>
  </div>
  <div class="hint">Entrée pour envoyer · Maj+Entrée pour saut de ligne</div>
</div>

<script>
const SYS = `Tu es un assistant spécialisé en estimation immobilière, travaillant aux côtés d'un agent immobilier professionnel. Conduis un entretien structuré pour collecter toutes les informations nécessaires à une estimation précise.

INSTRUCTIONS :
- Ton professionnel et formel. Vouvoyer systématiquement.
- Une seule question à la fois. Reformuler brièvement la réponse précédente.
- Indiquer l'étape sous la forme [Étape X/6 — Nom].

ÉTAPE 1 — IDENTIFICATION DU BIEN : Accueillir, se présenter, demander nature (maison/appartement/terrain), adresse ou ville, contexte.
ÉTAPE 2 — LOCALISATION & ENVIRONNEMENT : Situation géographique, accessibilité, nuisances ou atouts.
ÉTAPE 3 — SURFACE & COMPOSITION : Surface habitable, pièces/chambres/SDB, annexes. Terrain : surface, constructibilité, viabilisation.
ÉTAPE 4 — ÉTAT GÉNÉRAL & TRAVAUX : Année construction, travaux réalisés/à prévoir, état général, DPE.
ÉTAPE 5 — ÉQUIPEMENTS & PRESTATIONS : Chauffage, cuisine équipée, terrasse/balcon, double vitrage. Appt : étage, ascenseur, charges.
ÉTAPE 6 — INFORMATIONS COMPLÉMENTAIRES : Occupation, éléments juridiques, prix souhaité, délai.

CLÔTURE : Générer une fiche synthétique. Commencer par "### FICHE_SYNTHESE ###" puis organiser par catégorie en Markdown. Indiquer les manquants. Remercier.`;

let hist=[], busy=false, key='';

function launch(){
  const k=document.getElementById('kf').value.trim();
  const err=document.getElementById('serr');
  if(!k){err.textContent='Veuillez saisir votre clé API.';return;}
  if(!k.startsWith('sk-')){err.textContent='La clé doit commencer par sk-';return;}
  key=k;
  try{localStorage.setItem('immo_key',k);}catch(e){}
  document.getElementById('setup').style.display='none';
  call('');
}

window.addEventListener('load',()=>{
  try{const s=localStorage.getItem('immo_key');if(s)document.getElementById('kf').value=s;}catch(e){}
  document.getElementById('kf').addEventListener('keydown',e=>{if(e.key==='Enter')launch();});
});

const chat=document.getElementById('chat'), itx=document.getElementById('itx'), sbtn=document.getElementById('sbtn');
function setP(v){document.getElementById('pfill').style.width=Math.min(v,100)+'%';}

function addMsg(role,text,lbl){
  const w=document.createElement('div'); w.className='msg '+role;
  const av=document.createElement('div'); av.className='av'; av.textContent=role==='bot'?'🏛':'👤';
  const b=document.createElement('div'); b.className='bbl';
  if(lbl&&role==='bot'){const l=document.createElement('div');l.className='slbl';l.textContent=lbl;b.appendChild(l);}
  if(text.includes('### FICHE_SYNTHESE ###')){
    const pts=text.split('### FICHE_SYNTHESE ###');
    if(pts[0].trim()){const p=document.createElement('p');p.textContent=pts[0].trim();b.appendChild(p);}
    if(pts[1]){
      const f=document.createElement('div');f.className='fiche';
      const ft=document.createElement('div');ft.className='fiche-t';ft.textContent='📋 Fiche de synthèse';f.appendChild(ft);
      pts[1].trim().split(/\n(?=#{1,3} )/).forEach(s=>{
        const ls=s.split('\n').filter(l=>l.trim());if(!ls.length)return;
        const sec=document.createElement('div');
        if(ls[0].startsWith('#')){
          const st=document.createElement('div');st.className='fiche-st';st.textContent=ls[0].replace(/^#+\s*/,'');sec.appendChild(st);
          const c=document.createElement('p');c.innerHTML=ls.slice(1).map(l=>l.replace(/^\*\s*/,'• ').replace(/\*\*(.*?)\*\*/g,'<b>$1</b>')).join('<br>');sec.appendChild(c);
        }else{
          const c=document.createElement('p');c.innerHTML=ls.map(l=>l.replace(/^\*\s*/,'• ').replace(/\*\*(.*?)\*\*/g,'<b>$1</b>')).join('<br>');sec.appendChild(c);
        }
        f.appendChild(sec);
      });
      b.appendChild(f);
    }
    setP(100);
  }else{
    const p=document.createElement('p');
    p.innerHTML=text.replace(/\*\*(.*?)\*\*/g,'<b>$1</b>').replace(/\n/g,'<br>');
    b.appendChild(p);
  }
  w.appendChild(av);w.appendChild(b);chat.appendChild(w);chat.scrollTop=chat.scrollHeight;
}

function showTyp(){
  const w=document.createElement('div');w.className='msg bot';w.id='typ';
  const av=document.createElement('div');av.className='av';av.textContent='🏛';
  const b=document.createElement('div');b.className='bbl';
  const t=document.createElement('div');t.className='typ';t.innerHTML='<span></span><span></span><span></span>';
  b.appendChild(t);w.appendChild(av);w.appendChild(b);chat.appendChild(w);chat.scrollTop=chat.scrollHeight;
}
function hideTyp(){const e=document.getElementById('typ');if(e)e.remove();}
function getStep(t){const m=t.match(/\[Étape\s*(\d+)\/6/i);return m?parseInt(m[1]):null;}
function clean(t){return t.replace(/\[Étape\s*\d+\/6[^\]]*\]\s*/gi,'').trim();}

async function call(userText){
  if(busy)return;
  busy=true;sbtn.disabled=true;
  if(userText){addMsg('usr',userText);hist.push({role:'user',content:userText});}
  else{hist.push({role:'user',content:'Bonjour, je souhaite faire estimer mon bien immobilier.'});}
  showTyp();
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-api-key':key,
        'anthropic-version':'2023-06-01',
        'anthropic-dangerous-direct-browser-access':'true'
      },
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:SYS,messages:hist})
    });
    const d=await r.json();
    if(d.error)throw new Error(d.error.message);
    const raw=d.content?.[0]?.text||'Erreur inattendue.';
    hideTyp();
    const s=getStep(raw);
    if(s)setP((s/6)*92);
    addMsg('bot',clean(raw),s?`Étape ${s} / 6`:null);
    hist.push({role:'assistant',content:raw});
  }catch(e){
    hideTyp();
    addMsg('bot','Erreur : '+(e.message||'Connexion impossible. Vérifiez votre clé API.'));
  }
  busy=false;sbtn.disabled=false;itx.focus();
}

itx.addEventListener('input',()=>{itx.style.height='auto';itx.style.height=Math.min(itx.scrollHeight,110)+'px';});
itx.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();const v=itx.value.trim();if(v&&!busy){itx.value='';itx.style.height='auto';call(v);}}
});
sbtn.addEventListener('click',()=>{const v=itx.value.trim();if(v&&!busy){itx.value='';itx.style.height='auto';call(v);}});
</script>
</body>
</html>
